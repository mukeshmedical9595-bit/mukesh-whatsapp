# Copy these into your host's Environment Variables (Render → Environment).
# NEVER commit real secrets to git.
APP_ID=1039310715202655
CONFIG_ID=1403795661596400
GRAPH_VERSION=v21.0

# From Meta app dashboard → App settings → Basic → App secret (click Show).
APP_SECRET=paste_your_app_secret_here

# Any random string you invent; you'll paste the SAME value into Meta's webhook "Verify token" box.
VERIFY_TOKEN=make_up_a_random_string_here

# Left blank on first deploy — captured automatically when you complete the coexistence QR flow.
# After connecting, copy the ACCESS_TOKEN printed in the server logs back into here so it survives restarts.
ACCESS_TOKEN=
PHONE_NUMBER_ID=
WABA_ID=
